# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database
DATABASE_URL=sqlite:///./attendance.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin
ADMIN_DEFAULT_PASSWORD=Admin@2024!

# Face Recognition
FACE_SIMILARITY_THRESHOLD=0.70
FACE_CONFIDENCE_THRESHOLD=0.5

# Upload Limits
MAX_UPLOAD_SIZE_MB=5

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300

# Institution
INSTITUTION_NAME=Attendance System
INSTITUTION_EMAIL_DOMAIN=aec.edu.in
INSTITUTION_PHOTO_BASE_URL=/AEC/StudentPhotos

# Timetable
TIMETABLE_DAYS=6
TIMETABLE_PERIODS_PER_DAY=7

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
